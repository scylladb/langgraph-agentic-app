# Groq API key – https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ScyllaDB Cloud – copy these from the "Connect" tab of your cluster
# cloud.scylladb.com → My Clusters → <cluster> → Connect → Node.js
SCYLLADB_HOST=node-0.aws-us-east-1.xxxxxxxxxxxxxxxx.clusters.scylla.cloud
SCYLLADB_DC=AWS_US_EAST_1
SCYLLADB_USERNAME=scylla
SCYLLADB_PASSWORD=your_scylladb_password_here
